{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": false
  },
  "include": ["src/main.ts", "src/supervisor/**/*.ts"],
  "exclude": ["src/preload.ts", "src/renderer/**"]
}
